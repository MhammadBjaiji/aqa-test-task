{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "dom"],
    "types": ["node", "@playwright/test"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "*.ts",
    "tests/**/*",
    "api/**/*",
    "Pages/**/*",
    "data/**/*",
    "fixtures/**/*",
    "reporters/**/*"
  ],
  "exclude": ["node_modules"]
}
